# Enforce the engines field in package.json (refuses install on wrong Node version)
engine-strict=true

# Always use the exact version from pnpm-lock.yaml in CI; fail if lockfile is out of date
# (set per-environment via `CI=true`; pnpm reads this automatically)
prefer-frozen-lockfile=true

# Automatically install peer dependencies (pnpm default since v8, kept explicit)
auto-install-peers=true

# Don't fail if peer deps have version mismatches — warn instead
strict-peer-dependencies=false

# Save dependencies with caret ranges (e.g. ^1.2.3)
save-prefix=^

# Use the public npm registry (explicit beats inherited)
registry=https://registry.npmjs.org/

# Hoist commonly-needed types so tools that don't understand pnpm's symlinks still work
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
